rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isMod() {
      return isSignedIn() && (getUserData().role == 'mod' || getUserData().role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMod();
      allow create: if isSignedIn() && isOwner(userId) && 
                      request.resource.data.keys().hasAll(['email', 'balance', 'totalWagered', 'role', 'createdAt']) &&
                      request.resource.data.role == 'player';
      allow update: if isMod() || (isSignedIn() && isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'totalWagered']));
    }

    // --- MESSAGES ---
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.isSystem == false;
      allow create: if isMod() && request.resource.data.isSystem == true;
    }

    // --- REQUESTS ---
    match /withdrawalRequests/{requestId} {
      allow read: if isMod() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isMod() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason']);
    }

    match /depositRequests/{requestId} {
      allow read: if isMod() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isMod() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason']);
    }

    // --- SYSTEM ---
    match /system/config {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
